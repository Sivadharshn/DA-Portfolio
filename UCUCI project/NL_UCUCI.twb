      <aliases enabled='yes' />
      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.0v375d01ixqmkw1fl1zzp1ajpt3x].[sum:funded_amnt:qk]&quot;' value='Total Funded Amnt' />
          <alias key='&quot;[federated.0v375d01ixqmkw1fl1zzp1ajpt3x].[sum:total_pymnt:qk]&quot;' value='Total Payment' />
        </aliases>
      </column>
      <column caption='Loan Repayment Rate' datatype='real' default-format='n#,##0.00&quot;%&quot;;-#,##0.00&quot;%&quot;' name='[Calculation_0075606678761472]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([total_pymnt]) / SUM([funded_amnt]) * 100' />
      </column>
      <column caption='Default Rate' datatype='real' default-format='n#,##0.00&quot;%&quot;;-#,##0.00&quot;%&quot;' name='[Calculation_0075606678945793]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IIF([loan_status] = &quot;Charged Off&quot;, 1, 0)) / COUNT([id]) * 100' />
      </column>
      <column caption='Recovery-to-Funded Rate' datatype='real' default-format='n#,##0.00&quot;%&quot;;-#,##0.00&quot;%&quot;' name='[Calculation_0075606679121922]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IIF([loan_status] = &quot;Charged Off&quot;, [recoveries], 0))&#13;&#10;/&#13;&#10;SUM(IIF([loan_status] = &quot;Charged Off&quot;, [funded_amnt], 0))&#13;&#10;* 100' />
      </column>
      <column caption='Charged Off Flag' datatype='integer' name='[Calculation_0075606679265283]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [loan_status] = &quot;Charged Off&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Loan Count' datatype='integer' name='[Calculation_0075606680399876]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([id])' />
      </column>
      <column caption='installment_to_income_pct' datatype='real' name='[Calculation_0161643570135040]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [annual_inc] &gt; 0 THEN&#13;&#10;    [installment] / ([annual_inc] / 12) * 100&#13;&#10;END' />
