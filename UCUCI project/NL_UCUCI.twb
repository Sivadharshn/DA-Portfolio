    <worksheet name='Correlation Heatmap'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1'>&lt;Sheet Name&gt;</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='cleaned_lending_club_data' name='federated.0v375d01ixqmkw1fl1zzp1ajpt3x' />
          </datasources>
          <datasource-dependencies datasource='federated.0v375d01ixqmkw1fl1zzp1ajpt3x'>
            <column caption='Charged Off Flag' datatype='integer' name='[Calculation_0075606679265283]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [loan_status] = &quot;Charged Off&quot; THEN 1 ELSE 0 END' />
            </column>
            <column caption='DTI Band' datatype='string' name='[Calculation_1989306721906688]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [dti] &lt;= 10 THEN &quot;Low DTI&quot;&#13;&#10;ELSEIF [dti] &lt;= 20 THEN &quot;Moderate DTI&quot;&#13;&#10;ELSEIF [dti] &lt;= 30 THEN &quot;High DTI&quot;&#13;&#10;ELSEIF [dti] &lt;= 40 THEN &quot;Very High DTI&quot;&#13;&#10;ELSE &quot;Extreme DTI&quot;&#13;&#10;END' />
            </column>
            <column caption='Income band' datatype='string' name='[Calculation_1989306723352577]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [annual_inc] &lt;= 30000 THEN &quot;Very Low Income&quot;&#13;&#10;ELSEIF [annual_inc] &lt;= 60000 THEN &quot;Low Income&quot;&#13;&#10;ELSEIF [annual_inc] &lt;= 100000 THEN &quot;Middle Income&quot;&#13;&#10;ELSEIF [annual_inc] &lt;= 150000 THEN &quot;Upper Middle Income&quot;&#13;&#10;ELSEIF [annual_inc] &lt;= 250000 THEN &quot;High Income&quot;&#13;&#10;ELSE &quot;Very High Income&quot;&#13;&#10;END' />
            </column>
            <column caption='Loan Repayment Rate Row' datatype='real' name='[Calculation_1989306733379587]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[total_pymnt] / [funded_amnt] * 100' />
            </column>
            <column caption='Interest Rate vs LRR' datatype='real' name='[Calculation_1989306733592580]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CORR([int_rate], [Calculation_1989306733379587])' />
            </column>
            <column caption='DTI vs LRR' datatype='real' name='[Calculation_1989306733735941]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CORR([dti], [Calculation_1989306733379587])' />
            </column>
            <column caption='Annual Income vs LRR' datatype='real' name='[Calculation_1989306733850630]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CORR([annual_inc], [Calculation_1989306733379587])' />
            </column>
            <column caption='Installment vs LRR' datatype='real' name='[Calculation_1989306733998087]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CORR([installment], [Calculation_1989306733379587])' />
            </column>
            <column caption='Revolving Utilization vs LRR' datatype='real' name='[Calculation_1989306734092296]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CORR([revol_util], [Calculation_1989306733379587])' />
            </column>
            <column caption='Funded Amount vs LRR' datatype='real' name='[Calculation_1989306734194697]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CORR([funded_amnt], [Calculation_1989306733379587])' />
            </column>
            <column caption='Interest Rate vs Default Risk' datatype='real' name='[Calculation_1989306734301194]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CORR([int_rate], [Calculation_0075606679265283])' />
            </column>
