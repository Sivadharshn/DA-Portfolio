            <column caption='DTI Band' datatype='string' name='[Calculation_1989306721906688]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [dti] &lt;= 10 THEN &quot;Low DTI&quot;&#13;&#10;ELSEIF [dti] &lt;= 20 THEN &quot;Moderate DTI&quot;&#13;&#10;ELSEIF [dti] &lt;= 30 THEN &quot;High DTI&quot;&#13;&#10;ELSEIF [dti] &lt;= 40 THEN &quot;Very High DTI&quot;&#13;&#10;ELSE &quot;Extreme DTI&quot;&#13;&#10;END' />
            </column>
            <column caption='Income band' datatype='string' name='[Calculation_1989306723352577]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [annual_inc] &lt;= 30000 THEN &quot;Very Low Income&quot;&#13;&#10;ELSEIF [annual_inc] &lt;= 60000 THEN &quot;Low Income&quot;&#13;&#10;ELSEIF [annual_inc] &lt;= 100000 THEN &quot;Middle Income&quot;&#13;&#10;ELSEIF [annual_inc] &lt;= 150000 THEN &quot;Upper Middle Income&quot;&#13;&#10;ELSEIF [annual_inc] &lt;= 250000 THEN &quot;High Income&quot;&#13;&#10;ELSE &quot;Very High Income&quot;&#13;&#10;END' />
            </column>
            <column caption='Annual Inc' datatype='real' name='[annual_inc]' role='measure' type='quantitative' />
            <column-instance column='[dti]' derivation='Avg' name='[avg:dti:qk]' pivot='key' type='quantitative' />
            <column caption='Dti' datatype='real' name='[dti]' role='measure' type='quantitative' />
            <column caption='Funded Amnt' datatype='real' name='[funded_amnt]' role='measure' type='quantitative' />
            <column caption='Grade' datatype='string' name='[grade]' role='dimension' type='nominal' />
            <column caption='Issue D' datatype='string' name='[issue_d]' role='dimension' type='nominal' />
